# UCE / Neo4j (core engine)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_password_here
NEO4J_DATABASE=neo4j
NEO4J_SCHEMA_SAMPLE_SIZE=100
NEO4J_READ_TIMEOUT=30

# MCP transport (HTTP recommended)
NEO4J_TRANSPORT_MODE=http
NEO4J_MCP_HTTP_URL=http://127.0.0.1:8000/mcp/
NEO4J_MCP_HTTP_TIMEOUT=30
NEO4J_MCP_HTTP_RETRIES=3
NEO4J_MCP_HTTP_RETRY_DELAY=0.5

# MCP server (stdio fallback)
NEO4J_MCP_COMMAND=python -u -m neo4j_mcp.server --transport stdio

# LLM provider
LLM_PROVIDER=openai
LLM_FALLBACK=openai
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=2048
LLM_FORCE_JSON_RESPONSE=true

# Local LLM (OpenAI-compatible endpoint: Ollama/vLLM/LM Studio)
# To run fully local, use:
# LLM_PROVIDER=local
# LLM_FALLBACK=local
# LOCAL_LLM_BASE_URL=http://127.0.0.1:11434/v1
# LOCAL_LLM_API_KEY=local
# LOCAL_LLM_MODEL=gemma4:e4b

# LLM extraction behavior
LLM_REQUIRE_EVIDENCE=false
LLM_EVIDENCE_STRICT=false

# Optional overrides
# UCE_DOTENV_PATH=path/to/.env
# UCE_CONFIG_PATH=path/to/config.yaml
# UCE_MCP_TRANSPORT=http
# UCE_MCP_SERVER_HOST=127.0.0.1
# UCE_MCP_SERVER_PORT=9001
# UCE_MCP_SERVER_PATH=/mcp/

# RBAC + JWT (required when RBAC is enabled)
RBAC_ENABLED=false
RBAC_ENFORCE_MODE=advisory
RBAC_DENY_DEFAULT=true
RBAC_JWT_ISSUER=
RBAC_JWT_AUDIENCE=
RBAC_JWKS_URI=
RBAC_CLOCK_SKEW_SECONDS=60

# Identifier indexing (AST-lite, optional)
# Use ';' on Windows or ':' on Unix to separate multiple paths
UCE_IDENTIFIER_PATHS=src/server;src/api
UCE_IDENTIFIER_MAX_BYTES=200000
UCE_IDENTIFIER_MAX_COUNT=5000
