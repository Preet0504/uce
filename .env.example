NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=changeme
NEO4J_DATABASE=neo4j
NEO4J_SCHEMA_SAMPLE_SIZE=100
NEO4J_READ_TIMEOUT=30

NEO4J_TRANSPORT_MODE=http
NEO4J_MCP_HTTP_URL=http://127.0.0.1:8000/mcp/
NEO4J_MCP_HTTP_TIMEOUT=30
NEO4J_MCP_HTTP_RETRIES=3
NEO4J_MCP_HTTP_RETRY_DELAY=0.5

NEO4J_MCP_COMMAND=python -u -m uce.neo4j_mcp.server --transport stdio

LLM_PROVIDER=anthropic
LLM_FALLBACK=local
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
ANTHROPIC_MODEL=claude-sonnet-4-5
LLM_MAX_TOKENS=2048
LLM_FORCE_JSON_RESPONSE=true
LLM_REQUIRE_EVIDENCE=false
LLM_EVIDENCE_STRICT=false

UCE_DOTENV_PATH=.env
UCE_CONFIG_PATH=config.yaml
LOCAL_LLM_BASE_URL=http://127.0.0.1:11434/v1
LOCAL_LLM_API_KEY=local
LOCAL_LLM_MODEL=llama3:instruct

UCE_MCP_TRANSPORT=http

RBAC_ENABLED=true
RBAC_ENFORCE_MODE=enforced
RBAC_DENY_DEFAULT=true
RBAC_JWT_ISSUER=http://localhost:8080/realms/uce-realm
RBAC_JWT_AUDIENCE=uce-mcp
RBAC_JWKS_URI=http://localhost:8080/realms/uce-realm/protocol/openid-connect/certs
RBAC_CLOCK_SKEW_SECONDS=60
