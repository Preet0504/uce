# Copy to .env.docker and customize before running docker compose.

# Ports exposed on host
NEO4J_BOLT_PORT=7687
NEO4J_HTTP_PORT=7474
KEYCLOAK_PORT=8080
NEO4J_MCP_PORT=8000
UCE_MCP_PORT=9001

# Neo4j credentials
NEO4J_USER=neo4j
NEO4J_PASSWORD=testpassword
NEO4J_DATABASE=neo4j

# Keycloak bootstrap admin credentials
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_REALM=uce-realm

# RBAC auth settings used by UCE
RBAC_ENABLED=true
RBAC_ENFORCE_MODE=enforced
RBAC_DENY_DEFAULT=true
RBAC_JWT_AUDIENCE=uce-mcp
RBAC_JWT_ISSUER=http://localhost:8080/realms/uce-realm
RBAC_JWKS_URI=http://keycloak:8080/realms/uce-realm/protocol/openid-connect/certs
RBAC_CLOCK_SKEW_SECONDS=60

# LLM provider config for requirements/policies/rbac extraction
# Set OPENAI_API_KEY for cloud OpenAI, or set local provider values.
LLM_PROVIDER=openai
LLM_FALLBACK=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Local LLM alternative (OpenAI-compatible API)
# LLM_PROVIDER=local
# LLM_FALLBACK=local
# LOCAL_LLM_BASE_URL=http://host.docker.internal:11434/v1
# LOCAL_LLM_API_KEY=local
# LOCAL_LLM_MODEL=llama3:instruct

# Host path to analyze (mounted into /workspace/target)
UCE_TARGET_REPO=.

# Keycloak bootstrap script defaults
KEYCLOAK_BASE_URL=http://localhost:8080
KEYCLOAK_PUBLIC_BASE_URL=http://localhost:8080
