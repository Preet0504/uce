# Copy this file to client.env on the client machine.

# If the client loads a tar image, this tag must match the loaded image tag.
UCE_IMAGE=uce-engine:client

# Path to the project that UCE should analyze.
# This can be relative to this client_runner folder or an absolute path.
UCE_TARGET_REPO=../my-project

# External ports exposed on the client laptop.
UCE_MCP_PORT=9001
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_MCP_PORT=8000
KEYCLOAK_PORT=8080

# Local service credentials. Change these for anything beyond a quick demo.
NEO4J_USER=neo4j
NEO4J_PASSWORD=testpassword
NEO4J_DATABASE=neo4j
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_REALM=uce-realm
KEYCLOAK_ACCESS_TOKEN_LIFESPAN_SECONDS=3600

# RBAC settings.
RBAC_ENABLED=true
RBAC_ENFORCE_MODE=enforced
RBAC_DENY_DEFAULT=true
RBAC_JWT_AUDIENCE=uce-mcp
RBAC_CLOCK_SKEW_SECONDS=60
NEO4J_MCP_HTTP_HOST_HEADER=127.0.0.1

# The propose_change gate. enforced (default) means write_file/delete_file refuse to
# run without a gate_token minted by a prior propose_change() allow decision.
UCE_GATE_ENFORCEMENT=enforced
UCE_GATE_STRICT_DEFAULT=true
UCE_GATE_TOKEN_TTL_SECONDS=900

# Defense-in-depth: disables telemetry for any external Neo4j-MCP binary this stack
# might be pointed at (the neo4j-mcp service we ship in this compose file has none).
NEO4J_TELEMETRY=false

# LLM provider settings. Default is Anthropic (used for optional LLM-assisted
# requirements/policy ingestion only — the propose_change gate itself never calls
# an LLM). For a fully local, zero-outbound-network setup instead:
#   LLM_PROVIDER=local
#   LLM_FALLBACK=local
#   (leave ANTHROPIC_API_KEY/OPENAI_API_KEY unset, point LOCAL_LLM_BASE_URL at Ollama)
LLM_PROVIDER=anthropic
LLM_FALLBACK=anthropic
ANTHROPIC_API_KEY=replace_with_client_anthropic_key
ANTHROPIC_MODEL=claude-sonnet-4-5
LLM_MAX_TOKENS=2048
LLM_FORCE_JSON_RESPONSE=true
LLM_REQUIRE_EVIDENCE=false
LLM_EVIDENCE_STRICT=false

# Optional OpenAI/local provider settings.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LOCAL_LLM_BASE_URL=http://host.docker.internal:11434/v1
LOCAL_LLM_API_KEY=local
LOCAL_LLM_MODEL=llama3
